{
  "name": "@yasu/essay-grading",
  "version": "0.2.0",
  "private": true,
  "description": "YASU IELTS essay grading with band scores and annotated feedback",
  "type": "module",
  "main": "./dist/grading/index.js",
  "exports": {
    ".": "./dist/grading/index.js",
    "./api": "./dist/api/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"tsc --watch -p tsconfig.frontend.json\" \"tsx watch src/api/server.ts\"",
    "build:frontend": "node scripts/build-frontend.mjs",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build": "npm run build:frontend && npm run build:backend && node scripts/copy-prompts.mjs",
    "start": "cross-env NODE_ENV=production node dist/api/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.backend.json && tsc --noEmit -p tsconfig.frontend.json"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.2",
    "@upstash/redis": "^1.34.3",
    "busboy": "^1.6.0",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.5.0",
    "pdf-parse": "^2.4.5",
    "word-extractor": "^1.0.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.9.1",
    "@types/pdf-parse": "^1.1.5",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
